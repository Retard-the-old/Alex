# ============================================================================
# ALEX — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================================

# Server
PORT=3000
NODE_ENV=production

# WhatsApp Business API (Alex's number)
WHATSAPP_VERIFY_TOKEN=your-verify-token-here
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# Max's registered WhatsApp numbers (comma-separated)
MAX_REGISTERED_NUMBERS=+447700900001,+971501234567

# Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL_SMART=claude-opus-4-5-20250514
CLAUDE_MODEL_FAST=claude-sonnet-4-5-20250514

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/alex

# Redis
REDIS_URL=redis://localhost:6379

# Google APIs
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_CALENDAR_ID=primary

# Duffel API
DUFFEL_API_TOKEN=your-duffel-token

# SerpAPI (web search)
SERP_API_KEY=your-serp-key

# Whisper API (voice transcription)
OPENAI_API_KEY=your-openai-key

# Timezone
TIMEZONE=Asia/Dubai

# Daily Briefing Time (24h format)
BRIEFING_HOUR=11
BRIEFING_MINUTE=30
